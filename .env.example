# Copy to .env and adjust for your host.
#
# Local-only workstation:
# KRAMERIUS_BIND_ADDR=127.0.0.1
# KRAMERIUS_PUBLIC_HOST=127.0.0.1
#
# LAN test server:
# KRAMERIUS_BIND_ADDR=0.0.0.0
# KRAMERIUS_PUBLIC_HOST=10.0.120.30
# KEYCLOAK_PUBLIC_HOST=10.0.120.30

KRAMERIUS_BIND_ADDR=127.0.0.1
KRAMERIUS_PUBLIC_HOST=127.0.0.1
# Use keycloak.localhost only for localhost browser testing. For LAN, use the
# same reachable host as KRAMERIUS_PUBLIC_HOST or run configure-endpoints.sh.
KEYCLOAK_PUBLIC_HOST=keycloak.localhost

WEB_CLIENT_PORT=1234
ADMIN_CLIENT_PORT=1235
KRAMERIUS_API_PORT=8088
KRAMERIUS_DEBUG_PORT=5005
KRAMERIUS_AJP_PORT=8009
KEYCLOAK_PORT=8990
SOLR_PORT=8983
LOCK_SERVER_PORT_1=5701
LOCK_SERVER_PORT_2=5702
LOCK_SERVER_PORT_3=5703
PROCESS_MANAGER_PORT=8082
CURATOR_WORKER_PORT=8084
PUBLIC_WORKER_PORT=8086
KRAMERIUS_DB_PORT=15432
PROCESS_DB_PORT=25432

GIGATIFF_SOURCE_DIR=../gigatiff
GHCR_NAMESPACE=ghcr.io/bezverec
STACK_VERSION=stack-0.1.4
GIGATIFF_SERVER_VERSION=0.3.0
GIGATIFF_PORT=18082
GIGATIFF_INTERNAL_BASE_URL=http://host.docker.internal:18082/iiif/3
GIGATIFF_CACHE_NAMESPACE=gigatiff-server-response-v12-jp2-auto-fix
ADMIN_CLIENT_DOCKERFILE=../gigatiff-kramerius/ops/admin-client/Dockerfile.gigatiff

KEYCLOAK_REALM=kramerius
KEYCLOAK_CLIENT_ID=krameriusClient

DOCKHAND_PORT=3000
DASHY_PORT=18080
