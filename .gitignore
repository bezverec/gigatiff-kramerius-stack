# Runtime data and local state
logs/
temp/
cache/

# Kramerius import/runtime payloads
mnt/import/.kramerius4/convert/*
!mnt/import/.kramerius4/convert/.gitkeep
mnt/import/.kramerius4/import/*
!mnt/import/.kramerius4/import/.gitkeep
mnt/import/.kramerius4/data/
mnt/import/.kramerius4/statistics/

# Container database and index data
mnt/containers/*/
!mnt/containers/solr/
!mnt/containers/solr/data/
mnt/containers/solr/data/*/data/
mnt/containers/solr/data/zoo_data/

# Image/audio server payloads
mnt/imageserver/

# Local editor and OS noise
.env
.env.*
!.env.example
Thumbs.db
.DS_Store

