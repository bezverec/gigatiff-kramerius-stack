{
    "app":  {
                "code":  "gigatiff",
                "name":  {
                             "cs":  "GigaTIFF",
                             "en":  "GigaTIFF"
                         },
                "contactEmail":  "",
                "logo":  "/favicon.svg",
                "adminClientUrl":  "http://127.0.0.1:1235"
            },
    "api":  {
                "baseUrl":  "http://127.0.0.1:8088",
                "citationUrl":  "",
                "georefUrl":  ""
            },
    "i18n":  {
                 "defaultLanguage":  "cs",
                 "fallbackLanguage":  "en",
                 "supportedLanguages":  [
                                            "cs",
                                            "en"
                                        ]
             },
    "features":  {
                     "keycloak":  true,
                     "mapSearch":  false,
                     "mapProvider":  "allmaps",
                     "georef":  false,
                     "ai":  false,
                     "folders":  false,
                     "librarySwitch":  false
                 },
    "ui":  {
               "cookiebar":  false
           },
    "viewer":  {
                   "defaultMode":  "single",
                   "availableModes":  [
                                          "book",
                                          "single"
                                      ],
                   "rememberLastMode":  true,
                   "controls":  {
                                    "zoomIn":  true,
                                    "zoomOut":  true,
                                    "fullscreen":  true,
                                    "fitToScreen":  true,
                                    "fitToWidth":  true,
                                    "scrollMode":  true,
                                    "bookMode":  true,
                                    "rotate":  true,
                                    "selectArea":  true
                                },
                   "selectionControls":  {
                                             "text":  true,
                                             "export":  true,
                                             "share":  true
                                         }
               },
    "search":  {
                   "doctypes":  [
                                    "periodical",
                                    "periodicalvolume",
                                    "periodicalitem",
                                    "monograph",
                                    "map",
                                    "graphic",
                                    "collection",
                                    "page"
                                ]
               },
    "pages":  [
                  {
                      "id":  "terms",
                      "content":  {
                                      "cs":  [
                                                 "local-config/gigatiff/html/terms/terms.cs.html",
                                                 "local-config/gigatiff/html/terms/terms2.cs.html"
                                             ],
                                      "en":  [
                                                 "local-config/gigatiff/html/terms/terms.en.html",
                                                 "local-config/gigatiff/html/terms/terms2.en.html"
                                             ]
                                  }
                  }
              ]
}
